# The Ark API mail configuration
# Copy to .env and fill the SMTP password to enable real outbound mail.

# Deployment/runtime configuration
# Use ARK_STATE_DIR in hosted environments so account/session/history data lives on a persistent disk.
ARK_STATE_DIR=state
# Comma-separated origins allowed to call the API from browsers.
ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006
# Optional regex for preview domains, for example: https://.*\\.vercel\\.app
ALLOWED_ORIGIN_REGEX=

# Delivery modes:
# - auto: use SMTP when SMTP_HOST + EMAIL_FROM_ADDRESS are set, otherwise debug outbox
# - api: send through an email API provider such as Resend
# - smtp: force SMTP delivery
# - debug: always capture mail to state/email_outbox.json instead of sending
# - disabled: do not send and do not capture
EMAIL_DELIVERY_MODE=debug

# Optional API provider
# Supported values:
# - resend
EMAIL_PROVIDER=
RESEND_API_KEY=

# Sender identity
EMAIL_FROM_NAME=The Ark
EMAIL_FROM_ADDRESS=ron@chapmanandassociates.com
EMAIL_SUPPORT_ADDRESS=ron@chapmanandassociates.com

# Development helper: expose tokens in API responses while mail is in debug mode
EMAIL_DEBUG_EXPOSE_TOKENS=true

# Google Workspace / Gmail SMTP example
# Switch EMAIL_DELIVERY_MODE to smtp (or auto) after filling the password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=ron@chapmanandassociates.com
SMTP_PASSWORD=replace-with-google-workspace-app-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Resend API example
# Switch EMAIL_DELIVERY_MODE to api (or auto) after filling the API key.
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxx
